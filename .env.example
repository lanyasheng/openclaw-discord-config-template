# OpenClaw 环境变量示例

# LLM Provider API Keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_API_KEY=sk-your-openai-key
TAVILY_API_KEY=tvly-dev-your-tavily-key

# 阿里云百炼 (Qwen)
DASHSCOPE_API_KEY=sk-sp-your-dashscope-key

# 代理配置 (可选)
HTTP_PROXY=http://your-proxy-host:your-proxy-port
HTTPS_PROXY=http://your-proxy-host:your-proxy-port
ALL_PROXY=socks5://your-proxy-host:your-proxy-port

# Mem0 (可选)
MEM0_API_KEY=m0-your-mem0-key
