  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "your-token-here"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/path/to/your/.openclaw/skills",
        "/path/to/your/.openclaw/skills/self-improving-agent"
      ]
    },
    "install": {
      "nodeManager": "npm"
    },
    "entries": {
      "agent-browser": {
        "enabled": true,
        "env": {
          "AGENT_BROWSER_ENGINE": "lightpanda"
        }
      }
    }
  },
  "plugins": {
    "allow": [
      "acpx",
      "discord",
      "openclaw-mem0",
      "spawn-interceptor",
      "openclaw-mem-engine",
      "openclaw-mem",
      "openclaw-basic-memory"
    ],
    "load": {
      "paths": [
        "/path/to/your/.openclaw/extensions/spawn-interceptor"
      ]
    },
    "slots": {
      "memory": "openclaw-mem0"
    },
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all",
          "nonInteractivePermissions": "deny"
        }
      },
      "openclaw-mem0": {
        "enabled": true,
        "config": {
          "apiKey": "your-secret-here",
          "userId": "sly",
          "autoCapture": true,
          "autoRecall": true,
          "topK": 5,
          "searchThreshold": 0.55,
          "enableGraph": false
        }
      },
      "spawn-interceptor": {
        "enabled": true
      },
      "openclaw-mem": {
        "enabled": true,
        "config": {
          "captureMessage": false,
          "redactSensitive": true,
          "maxMessageLength": 500,
          "episodes": {
            "enabled": true,
            "captureConversationUser": true,
            "captureConversationAssistant": true,
            "captureToolCall": true,
            "captureToolResult": false,
            "payloadCapBytes": 1024,
            "maxSummaryLength": 200
          }
        }
      },
      "openclaw-mem-engine": {
        "enabled": false,
        "config": {
          "embedding": {
            "apiKey": "your-secret-here",
            "baseUrl": "http://localhost:11434/v1",
            "model": "nomic-embed-text",
            "maxChars": 6000,
            "headChars": 500
          },
          "autoRecall": {
            "enabled": true,
            "selectionMode": "tier_first_v1",
            "quotas": {
              "mustMax": 3,
              "niceMin": 2,
              "unknownMax": 1
            }
          },
          "autoCapture": {
            "enabled": true,
            "maxItemsPerTurn": 2,
            "capturePreference": true,
            "captureDecision": true,
            "captureTodo": false,
            "dedupeSimilarityThreshold": 0.92
          },
          "receipts": {
            "enabled": true,
            "verbosity": "low",
            "maxItems": 3
          },
          "scopePolicy": {
            "enabled": true,
            "defaultScope": "global",
            "validationMode": "normalize"
          },
          "budget": {
            "enabled": true,
            "maxChars": 1800,
            "minRecentSlots": 1,
            "overflowAction": "truncate_oldest"
          }
        }
      },
      "openclaw-basic-memory": {
        "enabled": true,
        "config": {
          "project": "openclaw",
          "memoryDir": "basic-memory/",
          "memoryFile": "MEMORY.md",
          "autoCapture": true,
          "indexInterval": 60,
          "debug": false
        }
      }
    },
